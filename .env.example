# Public website
NEXT_PUBLIC_SITE_URL=https://www.grimmfirepump.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Database
# Use one of these. Neon/Vercel Postgres are both supported by the current storage adapter.
DATABASE_URL=
POSTGRES_URL=

# Admin authentication
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=GRIMM Admin
ADMIN_ROLE=super_admin
ADMIN_SESSION_SECRET=

# Preferred: generate with `node scripts/hash-admin-password.mjs "your-strong-password"`
ADMIN_PASSWORD_HASH=

# Legacy fallback only. Keep empty after ADMIN_PASSWORD_HASH is configured.
ADMIN_PASSWORD=

# Third-party integrations
META_LEADS_VERIFY_TOKEN=
META_APP_SECRET=

# News automation
NEWS_DAILY_TARGET=4
NEWS_TIMEZONE=Asia/Shanghai
NEWS_LOOKBACK_HOURS=72
NEWS_DEDUP_DAYS=7
NEWS_MAX_RETRIES=3
NEWS_RELEVANCE_THRESHOLD=10
NEWS_AUTO_PUBLISH=true
NEWS_ALLOWED_LANGUAGES=en
NEWS_SOURCE_WHITELIST=
NEWS_SOURCE_BLACKLIST=
NEWS_ALERT_EMAIL=
NEWS_CRON_SECRET=
CRON_SECRET=

# Blog engineering brief automation (runs with the News cron)
BLOG_DAILY_TARGET=1
BLOG_AUTO_PUBLISH=true

# Sitemap maintenance and Google Search Console Sitemaps API
SITEMAP_CRON_SECRET=
SITEMAP_MANUAL_TOKEN=
GOOGLE_SEARCH_CONSOLE_ENABLED=false
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://www.grimmfirepump.com/
GOOGLE_SEARCH_CONSOLE_SITEMAP_URL=https://www.grimmfirepump.com/sitemap.xml
# Use one credential source. JSON/Base64 is recommended on Vercel; PATH is useful on a private server.
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_JSON=
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_BASE64=
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_PATH=

# Optional email / CRM integrations reserved for future wiring
RESEND_API_KEY=
CRM_WEBHOOK_URL=
